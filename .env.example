# ==================== ОБЯЗАТЕЛЬНЫЕ ====================

# Токен бота (получить у @BotFather)
BOT_TOKEN=

# Telegram API (получить на https://my.telegram.org)
# нужны для Local Bot API (контейнер bot-api) — файлы до 2 ГБ
API_ID=
API_HASH=

# порт bot-api на хосте (8097 — уникальный для bot_4_rutube,
# чтобы не конфликтовать с другими ботами на одном сервере)
BOT_API_PORT=8097

# Юзернейм бота (без @) — используется в подписи к медиа
BOT_USERNAME=your_bot_username

# ==================== БАЗА ДАННЫХ ====================

DB_HOST=postgres
DB_PORT=5432
DB_NAME=bot_4_rutube
DB_USER=bot_4_rutube
DB_PASSWORD=

# ==================== АДМИНЫ ====================

# Telegram ID админов через запятую
ADMIN_IDS=
ADMIN_USERNAME=admin

# ==================== ПРОКСИ ====================

# Резидентный SOCKS5 прокси (fallback если direct и WARP не работают)
# Цепочка: direct → SOCKS5 (если задан) → WARP
# Формат: socks5://user:pass@host:port  или  socks5://host:port
# Оставь пустым если нет — бот будет использовать только direct + WARP
SOCKS5_PROXY=

# ==================== ЛИМИТЫ И КЭШ ====================

# Кэш скачиваний в БД (дни) — не перекачиваем одно и то же видео
CACHE_TTL_DAYS=1

# Префлайт-фильтр: качества с оценкой > этого порога не показываются юзеру
MAX_QUALITY_SIZE_MB=2000
